<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.aura.attendix">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Bluetooth permissions (legacy + Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- Android 12+ Bluetooth permissions -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_SCAN"
        tools:targetApi="31" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        tools:targetApi="31" />

    <!-- Foreground service permissions -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".AuraApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.ATTENDIX"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".StudentHomeActivity"
            android:exported="false" />

        <activity
            android:name=".TeacherHomeActivity"
            android:exported="false" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ChangePasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".AttendanceHistoryActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- BLE Foreground Service -->
        <service
            android:name=".BleBroadcastService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- ── Phase 2: Role Dashboards ──────────────────────────── -->
        <activity android:name=".HodHomeActivity"
            android:exported="false" />

        <activity android:name=".AcademicCoordinatorHomeActivity"
            android:exported="false" />

        <activity android:name=".SuperAdminHomeActivity"
            android:exported="false" />

        <activity android:name=".SecurityHomeActivity"
            android:exported="false" />

        <activity android:name=".FinanceHomeActivity"
            android:exported="false" />

        <activity android:name=".LibrarianHomeActivity"
            android:exported="false" />

        <activity android:name=".ParentHomeActivity"
            android:exported="false" />

        <activity android:name=".ComingSoonActivity"
            android:exported="false" />

        <!-- ══ Phase B: Feature Parity Activities ══════════════ -->

        <!-- Security: QR + BLE hybrid scanner -->
        <activity android:name=".SecurityScanActivity"
            android:exported="false" />

        <!-- Student: Virtual ID (live QR) -->
        <activity android:name=".VirtualIdActivity"
            android:exported="false" />

        <!-- Student: Leave application form -->
        <activity android:name=".LeaveApplyActivity"
            android:exported="false" />

        <!-- Student: Leave history -->
        <activity android:name=".LeaveHistoryActivity"
            android:exported="false" />

        <!-- Teacher: Daily timetable + class control -->
        <activity android:name=".TimetableActivity"
            android:exported="false" />

        <!-- Teacher: Real-time live attendance monitor -->
        <activity android:name=".LiveMonitorActivity"
            android:exported="false" />

        <!-- Teacher / HOD / TG: Leave approval queue -->
        <activity android:name=".LeaveApprovalsActivity"
            android:exported="false" />

        <!-- Parent: Children attendance overview -->
        <activity android:name=".ChildAttendanceActivity"
            android:exported="false" />

        <!-- Finance / Student: Fee invoices list -->
        <activity android:name=".FeeInvoicesActivity"
            android:exported="false" />

    </application>

</manifest>

