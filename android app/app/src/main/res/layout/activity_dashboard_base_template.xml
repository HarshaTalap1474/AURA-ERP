<?xml version="1.0" encoding="utf-8"?>
<!--
    ╔══════════════════════════════════════════════════════════╗
    ║   AURA ERP — BASE DASHBOARD TEMPLATE                    ║
    ║   Copy this file and rename for each role dashboard:    ║
    ║     activity_hod_home.xml                               ║
    ║     activity_security_home.xml                          ║
    ║     activity_finance_home.xml  ... etc.                 ║
    ║                                                         ║
    ║   Replace ALL [PLACEHOLDER] tags with real content.     ║
    ╚══════════════════════════════════════════════════════════╝
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:fitsSystemWindows="true">

    <!-- ════════════════════════════════════
         TOP APP BAR — same across all roles
         ════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <!-- Left: Greeting + role label -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWelcomeName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hello, [Name]"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:fontFamily="font/poppins_bold"/>

            <!-- Replace text with the role label, e.g. "Head of Department" -->
            <TextView
                android:id="@+id/tvRoleLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ROLE LABEL]"
                android:textSize="13sp"
                android:textColor="@color/white_alpha_80"
                android:fontFamily="font/poppins_regular"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Right: Profile avatar icon -->
        <ImageView
            android:id="@+id/ivProfile"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_person"
            android:background="@drawable/circle_background_white"
            android:padding="10dp"
            android:contentDescription="Profile"
            android:clickable="true"
            android:focusable="true"/>

        <!-- Logout icon -->
        <ImageView
            android:id="@+id/ivLogout"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_logout"
            android:background="@drawable/circle_background_white"
            android:padding="10dp"
            android:layout_marginStart="10dp"
            android:contentDescription="Logout"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- ════════════════════════════════════
         SECTION LABEL (e.g. "QUICK ACTIONS")
         ════════════════════════════════════ -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUICK ACTIONS"
        android:textAllCaps="true"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:fontFamily="font/poppins_bold"
        android:letterSpacing="0.12"
        android:background="@drawable/pill_background_white_alpha"
        android:paddingHorizontal="16dp"
        android:paddingVertical="6dp"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="12dp"/>

    <!-- ════════════════════════════════════
         SCROLLABLE CARD GRID
         ════════════════════════════════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════
                 ROW 1 — Two cards side by side
                 Copy + paste as many rows as needed.
                 ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Card 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <!-- Replace src with relevant icon drawable -->
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/primary"
                            android:layout_marginBottom="12dp"
                            android:contentDescription="Icon"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[Card Title]"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold"
                            android:gravity="center"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[Card Subtitle]"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="font/poppins_regular"
                            android:gravity="center"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCard1"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Open"
                            android:textSize="13sp"
                            app:cornerRadius="12dp"
                            android:fontFamily="font/poppins_medium"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Card 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_chart"
                            app:tint="@color/primary"
                            android:layout_marginBottom="12dp"
                            android:contentDescription="Icon"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[Card Title]"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold"
                            android:gravity="center"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[Card Subtitle]"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="font/poppins_regular"
                            android:gravity="center"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCard2"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="Open"
                            android:textSize="13sp"
                            app:cornerRadius="12dp"
                            android:fontFamily="font/poppins_medium"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
            <!-- END ROW 1 — copy the above LinearLayout block for each additional row -->

        </LinearLayout>
    </ScrollView>

</LinearLayout>
