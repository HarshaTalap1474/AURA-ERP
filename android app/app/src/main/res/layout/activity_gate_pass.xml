<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <!-- Top App Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="@dimen/appbar_height"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/space_lg" android:background="@color/colorSurface">
        <ImageView android:id="@+id/ivBack" android:layout_width="@dimen/appbar_icon_size"
            android:layout_height="@dimen/appbar_icon_size" android:src="@drawable/ic_arrow_back"
            android:padding="8dp" app:tint="@color/colorOnSurface" android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" android:clickable="true" android:focusable="true"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Security Gate Pass"
            android:textSize="@dimen/text_title" android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/colorDivider"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="@dimen/screen_padding"
            android:gravity="center_horizontal">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="AUTHORISED EXIT" android:textSize="12sp" android:textStyle="bold"
                android:letterSpacing="0.1" android:textColor="@color/colorPrimary"
                android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Present this QR Code to Campus Security"
                android:textSize="@dimen/text_body" android:textColor="@color/colorTextSecondary"
                android:layout_marginBottom="@dimen/space_xl" android:textAlignment="center"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/space_md" style="@style/Widget.Aurora.Card"
                app:cardCornerRadius="24dp" app:cardElevation="8dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="@dimen/space_xl">

                    <FrameLayout android:layout_width="220dp" android:layout_height="220dp"
                        android:background="@drawable/bg_qr_frame" android:padding="12dp">
                        <ImageView android:id="@+id/ivGatePassQr" android:layout_width="match_parent"
                            android:layout_height="match_parent" android:contentDescription="Gate Pass QR"/>
                    </FrameLayout>

                    <TextView android:id="@+id/tvStudentDetails" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Loading details..."
                        android:textSize="@dimen/text_title" android:textStyle="bold"
                        android:textColor="@color/colorTextPrimary" android:layout_marginTop="@dimen/space_lg"/>

                    <TextView android:id="@+id/tvLeaveReason" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="-- Reason --"
                        android:textSize="@dimen/text_body" android:textColor="@color/colorTextSecondary"
                        android:layout_marginTop="4dp"/>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="APPROVED" app:chipBackgroundColor="#2010B981"
                        android:textColor="#10B981" android:layout_marginTop="@dimen/space_md"
                        app:chipCornerRadius="8dp" android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Note: This pass is valid for one-time exit only."
                android:textSize="@dimen/text_caption" android:textColor="@color/colorTextHint"
                android:layout_marginTop="@dimen/space_xl"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
