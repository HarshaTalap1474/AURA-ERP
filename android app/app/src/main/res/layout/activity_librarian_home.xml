<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background"
    android:fitsSystemWindows="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="20dp"
        android:paddingTop="24dp" android:paddingBottom="16dp" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvWelcomeName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Librarian"
                android:textSize="22sp" android:textStyle="bold" android:textColor="@color/white"
                android:fontFamily="font/poppins_bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Library Management" android:textSize="13sp"
                android:textColor="@color/white_alpha_80" android:fontFamily="font/poppins_regular"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <ImageView android:id="@+id/ivProfile" android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_person" android:background="@drawable/circle_background_white"
            android:padding="10dp" android:contentDescription="Profile" android:clickable="true" android:focusable="true"/>
        <ImageView android:id="@+id/ivLogout" android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_logout" android:background="@drawable/circle_background_white"
            android:padding="10dp" android:layout_marginStart="10dp" android:contentDescription="Logout"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="LIBRARY OPERATIONS" android:textAllCaps="true" android:textSize="11sp"
        android:textStyle="bold" android:textColor="@color/white" android:fontFamily="font/poppins_bold"
        android:letterSpacing="0.12" android:background="@drawable/pill_background_white_alpha"
        android:paddingHorizontal="16dp" android:paddingVertical="6dp"
        android:layout_marginStart="20dp" android:layout_marginBottom="12dp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:scrollbars="none"
        android:paddingHorizontal="16dp" android:paddingBottom="24dp" android:clipToPadding="false">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Row 1: Issue Book + Return Book -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView android:id="@+id/cardIssueBook"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp" app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp" android:gravity="center">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp"
                            android:src="@drawable/ic_fingerprint" app:tint="@color/success"
                            android:layout_marginBottom="12dp" android:contentDescription="Issue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Issue Book" android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold" android:gravity="center"
                            android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scan RFID / barcode" android:textSize="12sp"
                            android:textColor="@color/text_secondary" android:fontFamily="font/poppins_regular"
                            android:gravity="center" android:layout_marginBottom="16dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnIssueBook"
                            android:layout_width="match_parent" android:layout_height="40dp"
                            android:text="Issue" android:textSize="13sp" app:cornerRadius="12dp"
                            android:fontFamily="font/poppins_medium"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView android:id="@+id/cardOverdue"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp" app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp" android:gravity="center">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp"
                            android:src="@drawable/ic_calendar" app:tint="@color/error"
                            android:layout_marginBottom="12dp" android:contentDescription="Overdue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Overdue" android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold" android:gravity="center"
                            android:layout_marginBottom="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Fine tracker" android:textSize="12sp"
                            android:textColor="@color/text_secondary" android:fontFamily="font/poppins_regular"
                            android:gravity="center" android:layout_marginBottom="16dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnOverdue"
                            android:layout_width="match_parent" android:layout_height="40dp"
                            android:text="View" android:textSize="13sp" app:cornerRadius="12dp"
                            android:fontFamily="font/poppins_medium"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Row 2: Profile + Password -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardProfile"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardCornerRadius="20dp" app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp" android:gravity="center">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp"
                            android:src="@drawable/ic_profile" app:tint="@color/primary"
                            android:layout_marginBottom="12dp" android:contentDescription="Profile"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="My Profile" android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold" android:gravity="center"
                            android:layout_marginBottom="8dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnProfile"
                            android:layout_width="match_parent" android:layout_height="40dp"
                            android:text="Open" android:textSize="13sp" app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView android:id="@+id/cardPassword"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="8dp"
                    app:cardCornerRadius="20dp" app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white" android:clickable="true" android:focusable="true">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="20dp" android:gravity="center">
                        <ImageView android:layout_width="48dp" android:layout_height="48dp"
                            android:src="@drawable/ic_lock" app:tint="@color/primary"
                            android:layout_marginBottom="12dp" android:contentDescription="Password"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Password" android:textSize="14sp" android:textColor="@color/text_primary"
                            android:fontFamily="font/poppins_semibold" android:gravity="center"
                            android:layout_marginBottom="8dp"/>
                        <com.google.android.material.button.MaterialButton android:id="@+id/btnPassword"
                            android:layout_width="match_parent" android:layout_height="40dp"
                            android:text="Change" android:textSize="13sp" app:cornerRadius="12dp"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
