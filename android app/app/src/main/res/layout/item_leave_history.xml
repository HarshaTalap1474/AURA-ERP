<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp" app:cardElevation="4dp" app:cardBackgroundColor="@color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <TextView android:id="@+id/tvLeaveType" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Medical" android:textSize="15sp"
                android:textStyle="bold" android:textColor="#1F2937"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PENDING" android:textColor="@color/white" android:textSize="11sp"
                android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                android:background="@drawable/bg_status_chip"/>
        </LinearLayout>
        <TextView android:id="@+id/tvDates" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="01 Apr – 03 Apr" android:textSize="13sp" android:textColor="#6B7280" android:layout_marginTop="6dp"/>
        <TextView android:id="@+id/tvReason" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Reason" android:textSize="13sp" android:textColor="#374151" android:layout_marginTop="4dp"
            android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/tvAppliedOn" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Applied: 28 Mar" android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginTop="4dp"/>
            
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGatePass"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Show Gate Pass"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:icon="@drawable/ic_check_circle"
            app:iconSize="16dp"
            app:cornerRadius="6dp"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
